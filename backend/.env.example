# =============================================================================
# Code Review Bot — Environment Configuration
# =============================================================================

# LLM Provider: "ollama", "gemini", or "openai_compatible"
LLM_PROVIDER=ollama

# --- Ollama (local) ---
# Bare-metal: http://localhost:11434
# Docker on VPS with Ollama running on the host: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1

# --- Gemini (API) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI-compatible server (9Router, vLLM, OpenRouter, etc.) ---
# For backend in Docker calling 9Router on the host:
# OPENAI_COMPATIBLE_BASE_URL=http://host.docker.internal:20128/v1
# For backend running directly on the host:
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:20128/v1
OPENAI_COMPATIBLE_BASE_URL=http://host.docker.internal:20128/v1
OPENAI_COMPATIBLE_API_KEY=your_9router_api_key_here
OPENAI_COMPATIBLE_MODEL=your_9router_model_name
OPENAI_COMPATIBLE_TIMEOUT_SECONDS=120
OPENAI_COMPATIBLE_ENABLE_THINKING=false

# --- GitHub (optional, for private repos or higher rate limits) ---
GITHUB_TOKEN=

# --- AACR-Bench path (for benchmark scripts) ---
AACR_BENCH_PATH=../../aacr-bench

# --- Review runtime limits ---
AGENT_PARALLEL=true
AGENT_CONFIDENCE_THRESHOLD=0.2
AGENT_TIMEOUT_SECONDS=120
LLM_MAX_OUTPUT_TOKENS=8192
