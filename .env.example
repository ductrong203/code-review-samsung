# Shared docker-compose environment.
#
# Optional GitHub token. Recommended on VPS to avoid low unauthenticated
# GitHub API rate limits when fetching PR metadata, changed files, and PR heads.
GITHUB_TOKEN=

# Extension poller interval in seconds.
POLL_INTERVAL=120

# Review-time PR graph cleanup policy.
# Production default: remove temporary pr_<number>.db and PR worktree after review.
CRG_CLEANUP_AFTER_REVIEW=true
CRG_KEEP_PR_GRAPH=false
CRG_KEEP_FAILED_PR_GRAPH=false

# Extension storage layout inside Docker.
# Graph DBs and registry are persisted in the graph-data volume at /data/graphs.
# Source repos are cloned into the host ./repos mount and appear as /repos.
CRG_REPOS_BASE=/repos

# Reserved cache policy knobs for VPS sizing/retention.
CRG_MAX_CACHE_SIZE_GB=10
CRG_MAX_PR_GRAPH_AGE_HOURS=24
